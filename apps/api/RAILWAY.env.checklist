# Railway 환경변수 체크리스트 (API)
# DATABASE_URL=          # Railway Postgres 플러그인 연결
# DATABASE_SSL=true
# JWT_SECRET=
# JWT_EXPIRES_IN=7d
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=
# ADMIN_NAME=관리자
# CORS_ORIGIN=           # 웹 도메인 (쉼표로 여러 개 가능)
# PUBLIC_API_URL=        # API 공개 URL (로컬 업로드 URL 생성용)
# PORT=4000              # Railway가 자동 주입하기도 함
#
# Cloudflare R2 (권장)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
